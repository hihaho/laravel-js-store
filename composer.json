{
    "name": "hihaho/laravel-js-store",
    "description": "Laravel JS Store - Easily render data to your blade templates to use in your frontend, like Vue",
    "keywords": [
        "hihaho",
        "laravel-js-store"
    ],
    "homepage": "https://github.com/hihaho/laravel-js-store",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Robert Boes",
            "email": "robert@hihaho.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "illuminate/support": "^12.0|^13.0",
        "spatie/laravel-package-tools": "^1.14"
    },
    "require-dev": {
        "driftingly/rector-laravel": "^2.2",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.21",
        "orchestra/testbench": "^10.2|^11.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^11.5.50 || ^12.5.22",
        "rector/rector": "^2.0",
        "rector/type-perfect": "^2.1",
        "sandermuller/package-boost": "^0.9.0",
        "spaze/phpstan-disallowed-calls": "^4.6",
        "symplify/phpstan-extensions": "^12.0",
        "tomasvotruba/cognitive-complexity": "^1.0",
        "tomasvotruba/type-coverage": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "HiHaHo\\LaravelJsStore\\": "src"
        },
        "files": [
            "src/helpers/store.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "HiHaHo\\LaravelJsStore\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage",
        "phpstan": "vendor/bin/phpstan analyse --memory-limit=2G",
        "phpstan-simplified": "vendor/bin/phpstan analyse --memory-limit=2G --error-format symplify",
        "phpstan-clear-cache": "vendor/bin/phpstan clear-result-cache",
        "format": "vendor/bin/pint",
        "rector": "vendor/bin/rector process",
        "sync-ai": "vendor/bin/testbench package-boost:sync",
        "qa": [
            "@format",
            "@rector",
            "@phpstan"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "HiHaHo\\LaravelJsStore\\ServiceProvider"
            ],
            "aliases": {
                "LaravelJsStore": "HiHaHo\\LaravelJsStore\\StoreFacade"
            }
        }
    }
}
